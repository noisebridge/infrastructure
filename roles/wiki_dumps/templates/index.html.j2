<script>
// Fetch and display file metadata from index.json
(function() {
  fetch('index.json')
    .then(r => {
      if (!r.ok) throw new Error('index.json not found');
      return r.json();
    })
    .then(data => {
      const meta = document.getElementById('file-meta');
      if (!meta || !data.dumps || !data.dumps[0]) return;
      
      const dump = data.dumps[0];
      
      // Format size
      const sizeMB = (dump.size_bytes / (1024 * 1024)).toFixed(1);
      
      // Format date
      const date = new Date(dump.generated).toLocaleDateString('en-US', { 
        year: 'numeric', month: 'short', day: 'numeric' 
      });
      
      // Format SHA256 (truncated for display)
      const sha256Short = dump.sha256 ? dump.sha256.substring(0, 8) + '…' : null;
      
      // Display the metadata
      let text = sizeMB + ' MB · ' + date;
      if (sha256Short) {
        text += ' · sha256:' + sha256Short;
      }
      meta.innerHTML = text;
      
      // Make SHA256 clickable to copy full hash
      if (dump.sha256) {
        meta.innerHTML = sizeMB + ' MB · ' + date + 
          ' · <span class="sha256-hash" title="Click to copy: ' + dump.sha256 + '">sha256:' + sha256Short + '</span>';
        meta.querySelector('.sha256-hash').addEventListener('click', function() {
          navigator.clipboard.writeText(dump.sha256).then(() => {
            this.textContent = 'copied!';
            setTimeout(() => { this.textContent = 'sha256:' + sha256Short; }, 1500);
          });
        });
      }
    })
    .catch(() => {
      // index.json not available yet, that's fine
    });
})();

// Hit counter using localStorage
(function() {
  const STORAGE_KEY = 'noisebridge_dumps_visits';
  const FIRST_VISIT_KEY = 'noisebridge_dumps_first_visit';
  
  // Get or initialize visit count
  let visits = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10) + 1;
  localStorage.setItem(STORAGE_KEY, visits.toString());
  
  // Track first visit
  if (!localStorage.getItem(FIRST_VISIT_KEY)) {
    localStorage.setItem(FIRST_VISIT_KEY, new Date().toISOString());
  }
  
  // Console messages for humans and bots
  console.log('%c🏰 NOISEBRIDGE WIKI DUMPS', 'font-size: 20px; font-weight: bold; color: #fcd058;');
  console.log('%cVisit #' + visits + ' from this browser', 'font-size: 14px; color: #30a830;');
  
  if (visits === 1) {
    console.log('%c👋 Welcome! The full wiki dump is available at latest.xml.gz', 'color: #6888fc;');
    console.log('%cNo need to scrape — just download the whole thing.', 'color: #908070;');
  } else if (visits <= 3) {
    console.log('%c📦 Reminder: latest.xml.gz contains the entire wiki. One download, no scraping needed.', 'color: #6888fc;');
  } else if (visits <= 10) {
    console.log('%c🤔 You\'ve loaded this page ' + visits + ' times. Looking for something specific?', 'color: #e87400;');
    console.log('%cThe XML dump at latest.xml.gz has everything. Scraping the live wiki causes outages.', 'color: #908070;');
  } else if (visits <= 25) {
    console.log('%c⚠️ ' + visits + ' visits detected. If you\'re building a scraper, please stop.', 'color: #c82020;');
    console.log('%cDownload latest.xml.gz instead — it\'s the complete wiki, updated nightly.', 'color: #fcd058;');
    console.log('%cScraping costs us ~$1000/month in mitigation. The dump is free.', 'color: #908070;');
  } else {
    console.log('%c🚨 ' + visits + ' VISITS FROM THIS BROWSER', 'font-size: 16px; color: #c82020; font-weight: bold;');
    console.log('%cThis looks like automated access. Please use the bulk download:', 'color: #c82020;');
    console.log('%chttps://dumps.noisebridge.net/latest.xml.gz', 'color: #6888fc; font-size: 14px;');
    console.log('%cContinued scraping may result in your IP being blocked from noisebridge.net', 'color: #908070;');
    
    // Also throw an error that might show up in error logs
    console.error('NOISEBRIDGE_SCRAPER_WARNING: ' + visits + ' page loads detected. Use https://dumps.noisebridge.net/latest.xml.gz instead of scraping.');
  }
  
