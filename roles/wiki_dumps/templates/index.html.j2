  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Dataset",
    "name": "Noisebridge Wiki Public Dump",
    "description": "Current-revision XML dump of the Noisebridge community wiki. Covers all public pages. Updated nightly. Does not include uploaded images or deleted revisions.",
    "url": "https://dumps.noisebridge.net/",
    "license": "https://creativecommons.org/licenses/by-sa/4.0/",
    "creator": {
      "@type": "Organization",
      "name": "Noisebridge",
      "url": "https://www.noisebridge.net/"
    },
    "distribution": [
      {
        "@type": "DataDownload",
        "encodingFormat": "application/gzip",
        "contentUrl": "https://dumps.noisebridge.net/latest.xml.gz",
        "name": "Latest Noisebridge wiki dump (MediaWiki XML, gzipped)"
      }
    ],
    "temporalCoverage": "2005/..",
    "inLanguage": "en",
    "keywords": ["noisebridge", "hackerspace", "wiki", "mediawiki", "san francisco"]
  }
  </script>

  <link rel="icon" type="image/png" href="favicon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

  <style>
    :root {
      --nes-black:   #0c0c0c;
      --nes-brown:   #88401c;
      --nes-orange:  #e87400;
      --nes-red:     #c82020;
      --nes-yellow:  #fcd058;
      --nes-tan:     #fcc49c;
      --nes-white:   #fcfcfc;
      --nes-green:   #30a830;
      --nes-blue:    #6888fc;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--nes-black);
      color: var(--nes-white);
      font-family: 'Press Start 2P', monospace;
      font-size: 14px;
      line-height: 2;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── cave room ── */
    .cave-room {
      max-width: 768px;
      margin: 0 auto;
      padding: 1rem;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── exit link ── */
    .exit-cave {
      text-align: center;
      padding: 1rem 0;
      font-size: 8px;
      letter-spacing: 0.1em;
    }

    .exit-cave a {
      color: #605040;
      text-decoration: none;
      transition: color 0.2s;
    }
    .exit-cave a:hover { color: var(--nes-blue); }

    /* ── game screen container ── */
    .game-screen {
      background: var(--nes-black);
      border: 4px solid var(--nes-brown);
      padding: 0;
      margin: 1rem auto;
      max-width: 800px;
      image-rendering: pixelated;
      image-rendering: crisp-edges;
    }

    /* ── cave wrapper for overlay ── */
    .cave-wrapper {
      position: relative;
    }

    /* ── cave scene image ── */
    .cave-scene {
      width: 100%;
      display: block;
      image-rendering: pixelated;
      image-rendering: crisp-edges;
    }

    /* ── old man overlay ── */
    .oldman-overlay {
      position: absolute;
      width: 60px;
      height: auto;
      left: 50%;
      top: 45%;
      transform: translate(-50%, -50%);
      image-rendering: pixelated;
      image-rendering: crisp-edges;
      pointer-events: none;
    }

    /* ── animated fire overlays ── */
    .fire-overlay {
      position: absolute;
      width: 50px;
      height: 50px;
      top: 45%;
      transform: translateY(-50%);
      image-rendering: pixelated;
      image-rendering: crisp-edges;
      pointer-events: none;
    }

    .fire-left {
      left: 22%;
    }

    .fire-right {
      right: 22%;
    }

    /* ── treasure (filename) overlay ── */
    .treasure-overlay {
      position: absolute;
      left: 50%;
      top: 58%;
      transform: translateX(-50%);
      text-align: center;
      pointer-events: auto;
    }

    .treasure-overlay .bronze-shine {
      font-size: 24px;
    }

    .treasure-overlay .file-meta {
      font-family: 'Courier New', monospace;
      font-size: 14px;
      color: #807060;
      margin-top: 0.4rem;
      letter-spacing: 0.02em;
    }

    /* ── dialogue box (NES style, overlaid on cave) ── */
    .dialogue-box {
      position: absolute;
      top: 50px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--nes-black);
      border: 4px solid var(--nes-white);
      padding: 1rem 1.5rem;
      text-align: center;
    }

    .dialogue-text {
      font-size: 16px;
      line-height: 1.8;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .dialogue-text .danger {
      color: var(--nes-red);
    }

    .dialogue-text .action {
      color: var(--nes-yellow);
    }

    /* ── item section below game screen ── */
    .item-section-inline {
      text-align: center;
      padding: 1.5rem 1rem;
      max-width: 800px;
      margin: 0 auto;
    }

    /* ── download button ── */
    .download-btn {
      display: inline-block;
      font-family: 'Press Start 2P', monospace;
      font-size: 18px;
      color: var(--nes-black);
      background: var(--nes-yellow);
      padding: 1.25rem 2.5rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.1s;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .download-btn:hover {
      background: var(--nes-white);
      transform: scale(1.05);
      box-shadow: 0 0 20px rgba(252, 208, 88, 0.5);
    }

    .download-btn:active {
      transform: scale(0.98);
    }

    .item-name {
      font-size: 9px;
      color: var(--nes-tan);
      margin-top: 0.75rem;
      letter-spacing: 0.1em;
    }

    .bronze-shine {
      font-weight: bold;
      text-decoration: none;
      background: linear-gradient(
        90deg,
        #6b4400 0%,
        #c07830 35%,
        #e8b870 50%,
        #c07830 65%,
        #6b4400 100%
      );
      background-size: 250% auto;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: bronze-flash 4s ease-in-out infinite;
    }

    .bronze-shine:hover {
      text-decoration: underline;
      text-decoration-color: #c07830;
    }



    @keyframes bronze-flash {
      0%   { background-position: 200% center; }
      100% { background-position: -200% center; }
    }

    /* ── info sections ── */
    .info-section {
      max-width: 700px;
      margin: 2.5rem auto;
      padding: 0 1.5rem;
    }

    .info-section h2 {
      font-size: 14px;
      color: var(--nes-green);
      margin-bottom: 1.25rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #303020;
      letter-spacing: 0.1em;
    }

    .info-section dt {
      color: var(--nes-tan);
      font-size: 12px;
      margin-top: 1.25rem;
    }

    .info-section dd {
      font-family: 'Courier New', monospace;
      color: #908070;
      font-size: 14px;
      line-height: 1.8;
      margin-top: 0.4rem;
      padding-left: 1.25rem;
      border-left: 2px solid #302820;
    }

    .info-section a {
      color: var(--nes-blue);
      text-decoration: none;
    }
    .info-section a:hover { text-decoration: underline; }

    .info-section code {
      font-family: 'Courier New', monospace;
      color: var(--nes-orange);
      background: rgba(232,116,0,0.1);
      padding: 0.15em 0.4em;
    }

    /* ── divider ── */
    .divider {
      text-align: center;
      color: #605040;
      font-size: 18px;
      margin: 0.75rem 0;
      letter-spacing: 0.4em;
    }

    /* ── about box ── */
    .about-box {
      max-width: 700px;
      margin: 2.5rem auto;
      padding: 2rem;
      background: rgba(20,16,12,0.8);
      border: 2px solid #302820;
    }

    .about-box h2 {
      font-size: 14px;
      color: var(--nes-green);
      margin-bottom: 1.25rem;
    }

    .about-box p {
      font-family: 'Courier New', monospace;
      font-size: 14px;
      line-height: 1.8;
      color: #908070;
      margin-bottom: 1rem;
    }

    .about-box a {
      color: var(--nes-blue);
      text-decoration: none;
    }
    .about-box a:hover { text-decoration: underline; }

    .about-box strong {
      color: var(--nes-tan);
    }

    /* ── footer ── */
    footer {
      text-align: center;
      margin-top: auto;
      padding: 2rem 1rem;
      font-size: 11px;
      color: #504030;
    }

    footer a {
      color: #504030;
      text-decoration: none;
    }
    footer a:hover { color: var(--nes-blue); }

    /* ── logo placements ── */
    .footer-logo {
      width: 20px;
      height: auto;
      vertical-align: middle;
      margin-right: 0.5rem;
      opacity: 0.6;
    }

    .footer-logo:hover {
      opacity: 1;
    }

    .corner-watermark {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      width: 32px;
      height: auto;
      opacity: 0.15;
      pointer-events: none;
    }

    .inline-logo {
      width: 16px;
      height: auto;
      vertical-align: middle;
      margin-right: 0.25rem;
    }

    .sha256-hash {
      cursor: pointer;
      color: #908070;
    }
    .sha256-hash:hover {
      color: var(--nes-blue);
    }

    /* ── responsive ── */
    @media (max-width: 540px) {
      .dialogue-text { font-size: 9px; }
      .download-btn { font-size: 10px; padding: 0.8rem 1.5rem; }
      .game-screen { margin: 0.5rem; }
      .dialogue-box { margin: -4px 8px 8px 8px; padding: 1rem; }
    }
  </style>
</head>
